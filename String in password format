import java.util.*;
public class Main{
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        String str = sc.nextLine();
        char[] chars = str.toCharArray();
        int n = chars.length;
        for(int i=0;i<n;i++){
            chars[i] = '*';
        }
        System.out.print(chars);
        
    }
}
