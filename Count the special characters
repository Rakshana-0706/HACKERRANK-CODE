import java.util.*;
public class Main {
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        String str = sc.nextLine();
        int n = str.length();
        int count=0;
        for(int i=0;i<n;i++){
            char ch = str.charAt(i);
            if(!Character.isLetterOrDigit(ch) && !Character.isWhitespace(ch)){
                count++;
            }
        }
        System.out.println(count);
    }
}
